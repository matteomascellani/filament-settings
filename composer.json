{
    "name": "matteomascellani/filament-settings",
    "description": "Configurable settings module for Filament panels with key/value entries and scoped values",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0",
        "illuminate/database": "^11.0",
        "filament/filament": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Matteomascellani\\FilamentSettings\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Matteomascellani\\FilamentSettings\\FilamentSettingsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
